<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>

<BorderPane minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unoeste.compiladores.MainController">
    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <menus>
                <Menu mnemonicParsing="false" text="Arquivo">
                    <items>
                        <MenuItem mnemonicParsing="false" onAction="#onAbrir" text="Abrir" />
                        <MenuItem mnemonicParsing="false" onAction="#onSalvar" text="Salvar" />
                    </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Sobre" />
            <Menu mnemonicParsing="false" text="Programa">
              <items>
                <MenuItem mnemonicParsing="false" onAction="#onAnalisarLexico" text="Analisar Léxico" />
              </items>
            </Menu>
            </menus>
        </MenuBar>
    </top>
    <center>
        <StackPane fx:id="editor" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
